---
import PageLayout from '@/layouts/CommonPage.astro'
import {
  Button,
  Icon,
  PublicationSection,
  ResearchProjectSection,
  SimpleIcon
} from '@/components/user'
import config from '@/site-config'

const headings = [
  { depth: 2, slug: 'about-me', text: 'About Me' },
  { depth: 2, slug: 'research-interests', text: 'Research Interests' },
  { depth: 2, slug: 'publications', text: 'Publications' },
  { depth: 2, slug: 'open-source-projects', text: 'Open-source Projects' }
]
---

<PageLayout title='Academic' {headings} info={{ slug: '/academic', hideComment: true }}>
  <h2 id='about-me'>About Me<a class='anchor' href='#about-me'>#</a></h2>
  <p>
    I am a sophomore student at the School of <a href="https://jsjytx.neuq.edu.cn/" target="_blank" rel="noopener noreferrer">Computer and Communication Engineering</a>, <a href="https://www.neuq.edu.cn/" target="_blank" rel="noopener noreferrer">Northeastern University (Qinhuangdao)</a>. Currently, I am working as a Research Assistant at <a href="https://www.nju-link.com/en/" target="_blank" rel="noopener noreferrer">NJU-LINK Lab</a>, supervised by Professor <a href="https://yuxiangren.github.io/" target="_blank" rel="noopener noreferrer">Yuxiang Ren</a>, with a research focus on Agent.
  </p>

  <p>My research philosophy: Chase the trends of the times.</p>
  <p>
    Currently, I am researching the deployment and optimization of Agent applications in the field of personalized memory. Prior to this, I have practical experience in projects related to NLP, Diffusion, ESN, and other areas. For detailed information, please follow my blog and <a href="https://github.com/Lou-uo" target="_blank" rel="noopener noreferrer">GitHub</a>.
  </p>

  <p>Here is my academic CV, feel free to download it.</p>
  <Button title='下载简历' class='w-fit' href='/cv.pdf' target='_blank'>
    <Icon class='size-5' name='download' slot='before' />
  </Button>
  <h2 id='research-interests'>
    Research Interests<a class='anchor' href='#research-interests'>#</a>
  </h2>
  <div class='grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3'>
    {
      [
        {
          title: 'Personal Agent',
          description: 'Research the deployment and optimization of Agent applications in the field of personalized memory.',
          icon: 'ros'
        }
        // {
        //   title: '研究方向 2',
        //   description: '关于该研究方向的详细描述，包括关键词等。',
        //   icon: 'pytorch'
        // }
      ].map((interest) => (
        <div class='group relative overflow-hidden rounded-xl border border-border bg-card p-4 transition-all hover:border-foreground/25 hover:shadow-md'>
          <div class='flex items-start gap-4'>
            <div class='flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 transition-colors group-hover:bg-primary/20'>
              <SimpleIcon
                class='size-5 text-primary transition-transform duration-300 group-hover:scale-110'
                name={interest.icon}
              />
            </div>
            <div class='flex-1'>
              <p class='text-xl font-medium leading-tight text-foreground transition-colors group-hover:text-primary'>
                {interest.title}
              </p>
              <p class='text-sm leading-relaxed text-muted-foreground'>{interest.description}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
  <h2 id='publications'>Publications<a class='anchor' href='#publications'>#</a></h2>
  <PublicationSection
    publications={[
      {
        title:
          'ESN Anomaly Detection',
        authors: [
          { name: 'XX', isEqual: true }
        ],
        venue: 'XX',
        year: '2026',
        type: 'XX',
        abstract:
          '…………',
        links: [
          { type: 'github', href: 'https://github.com/Lou-uo/ESN-for-Anomaly-Dectection', label: 'Code' }
        ],
        status: 'writing'
      },
      {
        title:
          'Agent ???',
        authors: [
          { name: 'XX', isEqual: true }
        ],
        venue: 'XX',
        year: '2026',
        type: 'XX',
        abstract:
          '…………',
        links: [
          { type: 'website', href: '#' },
          { type: 'arxiv', href: '#' },
          { type: 'github', href: '#', label: 'Code' }
        ],
        status: 'writing'
      }
    ]}
  />
  <h2 id='open-source-projects'>
    Open-source Projects<a class='anchor' href='#open-source-projects'>#</a>
  </h2>
  <ResearchProjectSection
    projects={[
      {
        title: 'self-made-skills',
        description:
          'Integrated skills for Claude/Codex, including user profiling based on historical conversations and graduate school recommendation positioning',
        category: 'agent skill',
        status: 'active',
        links: [
          { type: 'github', href: 'https://github.com/Lou-uo/self-made-skills', label: 'Code' }
        ]
      }
    ]}
  />
</PageLayout>

<script
  is:inline
  type='module'
  data-astro-rerun
  define:vars={{ npmCDN: config.npmCDN, walineServer: config.integ.waline.server }}
>
  const normalizePath = (path) => {
    if (path === '/') return path
    return path.endsWith('/') ? path.slice(0, -1) : path
  }

  const loadPageviewCount = async () => {
    const pageview = await import(`${npmCDN}/@waline/client@v3/dist/pageview.js`)
    pageview.pageviewCount({
      serverURL: walineServer,
      path: normalizePath(window.location.pathname)
    })
  }

  await loadPageviewCount()
</script>
